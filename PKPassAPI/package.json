{
	"name": "pk-pass-api",
	"type": "module",
	"scripts": {
		"dev": "bun run --watch src/main.ts",
		"start": "bun run src/main.ts",
		"inspect": "bun run --inspect-brk src/main.ts",
		"build": "bun build --compile --minify --sourcemap --target=bun --outfile ./dist/server ./src/main.ts",
		"typecheck": "tsc"
	},
	"devDependencies": {
		"@types/bun": "1.3.11",
		"@varlock/1password-plugin": "^0.3.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@bwip-js/node": "^4.8.0",
		"elysia": "1.4.28",
		"passkit-generator": "^3.5.7",
		"varlock": "^0.6.2",
		"zod": "^4.3.6"
	}
}
